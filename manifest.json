{
  "name": "Wawe — AI File Enhancer",
  "short_name": "Wawe",
  "description": "AI-powered file enhancer. Video, audio, immagini, documenti.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#080c14",
  "theme_color": "#080c14",
  "orientation": "any",
  "scope": "/",
  "lang": "it",
  "icons": [
    { "src": "public/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "public/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "video/*": [".mp4",".mov",".avi",".mkv",".webm"],
        "audio/*": [".mp3",".wav",".flac",".aac",".ogg"],
        "image/*": [".jpg",".jpeg",".png",".gif",".webp"],
        "application/pdf": [".pdf"],
        "application/zip": [".zip"],
        "*/*": [".pptx",".docx",".xlsx",".m3u",".m3u8",".rar",".7z"]
      }
    }
  ]
}
